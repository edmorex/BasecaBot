// BasecaBot data model.
//
// Uses `env("DATABASE_URL")` so the exact same schema runs on SQLite locally
// and Postgres on a server — switch by changing DATABASE_URL only.
// (When moving to Postgres, change provider below to "postgresql".)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A Twitch user the bot has seen. Keyed by the stable Twitch user id.
///
/// Identity model:
///  - `login` is the Twitch account name; the canonical username is "@" + login.
///  - `displayName` is the human-readable name used in generated output. It
///    starts as the Twitch display name and syncs from Twitch on every touch
///    UNTIL the user customizes it (`displayNameLocked` = true), after which the
///    bot never overwrites it.
///  - `names` is the user's row in the GLOBAL name index (`UserName`), which is
///    what commands resolve typed names against. See docs/user-accounts.md.
///
/// Extensibility: add first-class structured fields (e.g. `birthday DateTime?`,
/// `pronouns String?`) as nullable columns here; use `UserPreference` (key/value)
/// for feature opt-in/outs and other loosely-structured flags.
model User {
  id                String   @id // Twitch user id
  login             String   @unique
  displayName       String
  displayNameLocked Boolean  @default(false) // true once the user edits it
  avatarUrl         String? // Twitch profile_image_url, captured at login
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())

  points       PointsBalance[]
  events       EventLog[]
  names        UserName[]
  preferences  UserPreference[]
  createdLists List[]           @relation("ListCreator")
  listEntries  ListEntry[]      @relation("ListEntryAuthor")
  quotes       Quote[]          @relation("QuoteCreator")
  quotedIn     Quote[]          @relation("QuotedUser")
  firstStat     FirstStat?
  firstCheckins FirstCheckin[]
}

/// Cumulative all-time "!first" scoreboard for a user. Only top-10 finishes
/// contribute; averages are stored as running sums so they update atomically
/// (avgTime = sumTimeSeconds/topTens, avgPlace = sumPlace/topTens).
model FirstStat {
  userId         String @id
  firsts         Int    @default(0) // literal 1st-place finishes
  topTens        Int    @default(0) // finishes in places 1..10 (the averages' divisor)
  sumTimeSeconds Int    @default(0) // Σ check-in seconds over top-10 finishes
  sumPlace       Int    @default(0) // Σ place over top-10 finishes
  points         Int    @default(0) // cumulative ranking points (11 - place, per top-10 finish)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// One "!first" check-in. Recorded for EVERY place (incl. 11+) so repeats are
/// detectable and the place counter keeps climbing; only places 1..10 feed
/// FirstStat. `streamKey` is the live stream's start time — one race per stream.
model FirstCheckin {
  id          Int      @id @default(autoincrement())
  streamKey   String
  userId      String
  place       Int // 1-based check-in order this stream
  timeSeconds Int // seconds after the stream started
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([streamKey, userId]) // one check-in per user per stream
  @@index([streamKey])
}

/// The GLOBAL name index: every name any user can be referenced by, in ONE
/// namespace. `normalized` (lowercased, '@' stripped) is unique across all users
/// and all kinds, so a typed name resolves to at most one person — that single
/// unique index is what makes display names and aliases unable to shadow another
/// user's Twitch account. See docs/user-accounts.md.
///
/// `kind` records where the name came from and sets precedence when two claims
/// collide (login > display > alias):
///  - "login"   one per user, maintained from Twitch. Always wins: a real account
///              reclaims its own name, evicting any squatter's display/alias.
///  - "display" only when the user has locked a CUSTOM display name that differs
///              from their login. Twitch-synced display names are just the login
///              recapitalized, so they normalize to it and need no row.
///  - "alias"   user-defined extra names, any number.
model UserName {
  id         Int      @id @default(autoincrement())
  userId     String
  name       String // as entered, for display
  normalized String   @unique // lowercased, '@'-stripped — one global namespace
  kind       String // "login" | "display" | "alias"
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, kind])
}

/// Loosely-structured per-user preferences / feature opt-in-outs. The extension
/// point for future settings that don't warrant their own column.
model UserPreference {
  id     Int    @id @default(autoincrement())
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

/// Points balance per user (the bot serves a single channel).
model PointsBalance {
  id      Int    @id @default(autoincrement())
  userId  String @unique
  balance Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Admin-defined custom command. Two kinds:
///  - 'trigger': invoked by `!word`. Has one primary trigger word (`name`) plus
///    any number of alias words — all stored in CommandTrigger.
///  - 'phrase':  fires when its `name` text appears anywhere in a chat message
///    (case-insensitive substring). Phrases have no aliases.
model CustomCommand {
  id             Int      @id @default(autoincrement())
  kind           String   @default("trigger") // 'trigger' | 'phrase'
  /// Primary trigger word (no '!'), or the phrase text.
  name           String
  /// Message sent to chat. Null/empty => silent (fires but says nothing).
  response       String?
  /// Optional user-defined grouping label (e.g. People, Pets, Facts). Null = ungrouped.
  group          String?
  /// PermissionLevel numeric value (see core/events.ts).
  permission     Int      @default(0)
  /// Seconds before anyone can retrigger (0 = none). Takes priority over user.
  globalCooldown Int      @default(0)
  /// Seconds before the same user can retrigger (0 = none). Never < global.
  userCooldown   Int      @default(0)
  enabled        Boolean  @default(true)
  usageCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  triggers CommandTrigger[]

  @@unique([kind, name])
  @@index([kind, enabled])
}

/// A trigger word (normalized: lowercase, no '!', globally unique). Three shapes:
///  - primary (isPrimary=true): a custom command's own word (== command.name); `commandId` set.
///  - custom alias: `commandId` set (points at another custom command).
///  - built-in alias: `builtinTarget` set (re-dispatches to a built-in command,
///    e.g. `!addme` -> `!wheel add $(sender)`); `commandId` is null.
/// Exactly one of `commandId` / `builtinTarget` is set (enforced in code). An
/// alias can be enabled/disabled independently (`enabled`) and never points to
/// another alias.
model CommandTrigger {
  id        Int     @id @default(autoincrement())
  word      String  @unique
  isPrimary Boolean @default(false)
  /// Alias only: the target command's FULL argument string (may hold $() vars).
  /// It is NOT combined with the caller's args — forward those with $(args).
  args      String?
  /// Alias only: independent enable flag (a disabled alias is a no-op).
  enabled   Boolean @default(true)
  commandId Int?
  /// Built-in alias only: the built-in command word this re-dispatches to.
  builtinTarget String?

  command CustomCommand? @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@index([commandId])
}

/// A named, mod-managed collection of text entries (per channel). Referenced by
/// a single case-insensitive word (`name`); `displayName` is an optional longer
/// label for display. `addPermission` is the PermissionLevel required to add an
/// entry via `!list add` (default Moderator). If it is higher than Moderator
/// (Broadcaster/Admin), mods are also blocked from managing the list.
model List {
  id            Int      @id @default(autoincrement())
  name          String   @unique // reference word (lowercase, no spaces)
  displayName   String? // optional human-friendly name
  description   String?
  addPermission Int      @default(3) // PermissionLevel (see core/events.ts); default Moderator
  createdById   String? // Twitch user id of the creator
  createdByName String? // creator display name, snapshotted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator User?       @relation("ListCreator", fields: [createdById], references: [id], onDelete: SetNull)
  entries ListEntry[]
}

/// One entry in a List. Records who added it and when.
model ListEntry {
  id          Int      @id @default(autoincrement())
  listId      Int
  text        String
  addedById   String? // Twitch user id of who added it
  addedByName String? // adder display name, snapshotted
  createdAt   DateTime @default(now())

  list    List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  addedBy User? @relation("ListEntryAuthor", fields: [addedById], references: [id], onDelete: SetNull)

  @@index([listId])
}

/// A saved quote. `id` is the quote number shown in chat. Records who is quoted
/// (`quotedUser`, a login/name without '@'), the game being played when it was
/// captured, the quote date (`quoteDate`, "YYYY-MM-DD"), and who added it.
model Quote {
  id            Int      @id @default(autoincrement())
  text          String
  /// Snapshot of the name as entered. For a LINKED quote this is only a fallback
  /// — display renders the live display name of `quotedUserRef` so renames follow
  /// automatically. For an unlinked quote (a name that matched no Twitch account)
  /// it is the only record of who was quoted.
  quotedUser    String
  /// Twitch user id of the person quoted, when the name resolved to a real
  /// account. Null for unlinked quotes (e.g. "chat", a guest, an imported name).
  quotedUserId  String?
  game          String? // game/category at capture time
  quoteDate     String // "YYYY-MM-DD"
  createdById   String? // Twitch user id of who added it ("Quoted By")
  createdByName String? // adder display name, snapshotted
  createdAt     DateTime @default(now())

  creator       User? @relation("QuoteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  quotedUserRef User? @relation("QuotedUser", fields: [quotedUserId], references: [id], onDelete: SetNull)
}

/// Runtime settings, editable without redeploying.
model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

/// Audit log of notable events (subs, bits, donations, raids...).
model EventLog {
  id        Int      @id @default(autoincrement())
  type      String
  userId    String?
  amount    Int?
  meta      String? // JSON blob
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
}
