# ─── BasecaBot configuration ────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# ── Twitch ──────────────────────────────────────────────────────────────────
# Create an app at https://dev.twitch.tv/console/apps to get a client id/secret.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# OAuth tokens for the BOT account (the "BasecaBot" account that posts in chat).
# Authorize this while logged into Twitch AS THE BOT ACCOUNT, with scopes:
#   chat:read chat:edit
TWITCH_BOT_USERNAME=basecabot
TWITCH_BOT_ACCESS_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=

# The channel(s) the bot should join. Comma-separated for multiple.
TWITCH_CHANNELS=your_channel

# The broadcaster account login (your channel — the stream owner).
TWITCH_BROADCASTER_USERNAME=your_channel

# OAuth tokens for the BROADCASTER account (your main channel account). EventSub
# for subs/bits/follows can ONLY be authorized by the channel owner, so this is a
# second token. Authorize while logged in AS YOUR MAIN ACCOUNT, with scopes:
#   channel:read:subscriptions bits:read moderator:read:followers
TWITCH_BROADCASTER_ACCESS_TOKEN=
TWITCH_BROADCASTER_REFRESH_TOKEN=

# Twitch logins that should be treated as bot admins (comma-separated).
# The broadcaster is always an admin regardless of this list.
BOT_ADMINS=your_channel

# ── Database ────────────────────────────────────────────────────────────────
# Local (SQLite). NOTE: file: URLs are resolved relative to prisma/schema.prisma,
# so this path produces prisma/basecabot.db at the project root.
DATABASE_URL="file:./basecabot.db"
# Server (Postgres) example — swap the line above for something like:
# DATABASE_URL="postgresql://user:pass@localhost:5432/basecabot?schema=public"

# ── WebSocket hub (web-app integration) ─────────────────────────────────────
WS_HUB_PORT=8080
# Shared secret web apps must present to connect to the hub.
WS_HUB_SECRET=change-me

# ── Misc ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Comma-separated plugin names to disable (default: all discovered plugins enabled).
DISABLED_PLUGINS=

# Dev/testing only: set to 'true' to enable the eventSimulator plugin, which lets
# the webapps/event-sim harness inject fake sub/bits/raid/etc events. Leave blank
# (off) in production — it can fabricate events that award points.
EVENT_SIM_ENABLED=

# ── Server deployment — see docs/DEPLOYMENT.md ────────────────────────────────
# TLS/HTTPS and the domain are handled by the separate `edge-server` project now,
# so DOMAIN / ACME_EMAIL live in that project's .env — NOT here. The bot just runs
# on the shared `edge` Docker network. In the container, DATABASE_URL is overridden
# to file:/data/basecabot.db by docker-compose (a persistent volume), so the local
# value above is used only for local dev.
